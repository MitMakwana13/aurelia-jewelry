generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      String    @default("USER")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fullName            String?
  phone               String?
  onboardingCompleted Boolean   @default(false)
  isActive            Boolean   @default(true)
  lastLogin           DateTime?
  wishlistItems       WishlistItem[]
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Product {
  id              String           @id @default(uuid())
  handle          String           @unique
  title           String
  description     String
  categorySlug    String
  collectionSlugs String[]
  tags            String[]
  metals          String[]
  sizes           String[]
  basePrice       Float
  images          Json
  featured        Boolean          @default(false)
  trending        Boolean          @default(false)
  newArrival      Boolean          @default(false)
  bestseller      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  badge           String?
  hoverImage      String?
  inStock         Boolean          @default(true)
  isActive        Boolean          @default(true)
  primaryImage    String?
  seoDescription  String?
  seoTitle        String?
  sortOrder       Int              @default(0)
  analytics       AnalyticsEvent[]
  diamondDetail   DiamondDetail?
  gemstoneDetail  GemstoneDetail?
  inquiries       Inquiry[]
  variants        Variant[]
  wishlistItems   WishlistItem[]
}

model Variant {
  id        String  @id @default(uuid())
  productId String
  title     String
  metal     String
  size      String?
  price     Float
  currency  String  @default("INR")
  available Boolean @default(true)
  sku       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id                String   @id @default(uuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  amount            Float
  currency          String   @default("INR")
  status            String   @default("CREATED")
  shiprocketOrderId String?
  customerDetails   Json?
  items             Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Inquiry {
  id           String    @id @default(uuid())
  name         String
  email        String?
  phone        String
  type         String    @default("GENERAL")
  productId    String?
  productName  String?
  budget       String?
  message      String
  status       String    @default("NEW")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  advancePaid  Float?
  assignedTo   String?
  followUpDate DateTime?
  priority     String    @default("NORMAL")
  quotedAmount Float?
  source       String    @default("website")
  utmMedium    String?
  utmSource    String?
  product      Product?  @relation(fields: [productId], references: [id])
}

model CustomRequest {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String
  jewelryType String
  metal       String?
  gemstone    String?
  description String
  budget      String?
  occasion    String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GemstoneDetail {
  id                String   @id @default(uuid())
  productId         String   @unique
  stoneName         String
  hindiName         String?
  planet            String?
  zodiacSigns       String[]
  benefits          String[]
  rattiWeight       Float?
  originCountry     String?
  treatment         String?
  certificateLab    String?
  certificateNumber String?
  minPricePerRatti  Float?
  maxPricePerRatti  Float?
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model DiamondDetail {
  id                String  @id @default(uuid())
  productId         String  @unique
  shape             String?
  carat             Float?
  colorGrade        String?
  clarityGrade      String?
  cutGrade          String?
  certificateLab    String?
  certificateNumber String?
  fluorescence      String?
  pricePerCaratInr  Float?
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ExchangeRate {
  id             String   @id @default(uuid())
  currencyCode   String   @unique
  currencySymbol String?
  rateToInr      Float
  lastUpdated    DateTime @default(now())
  updatedBy      String?
}

model GoldRate {
  id                 String   @id @default(uuid())
  date               DateTime @default(now())
  gold22kPerGramInr  Float?
  gold24kPerGramInr  Float?
  silverPerGramInr   Float?
  platinumPerGramInr Float?
  source             String   @default("manual")
  createdBy          String?
  createdAt          DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  isActive     Boolean  @default(true)
  source       String?
  subscribedAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String?
  valueJson Json?
  label     String?
  category  String?
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  productId String?
  sessionId String?
  userAgent String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}
