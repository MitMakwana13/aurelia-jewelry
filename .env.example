# ────────────────────────────────────────────────────────────────────────────────
# Aurelia Fine Jewelry — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ────────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Commerce adapter ─────────────────────────────────────────────────────────
# "mock" (default — reads from /data) or "shopify"
COMMERCE_ADAPTER=mock

# ── Shopify Storefront API (only if COMMERCE_ADAPTER=shopify) ─────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_ / sk_test_) during development.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key_here
STRIPE_SECRET_KEY=your_secret_key_here

# Webhook secret — get from: https://dashboard.stripe.com/webhooks
# For local testing run: stripe listen --forward-to localhost:3000/api/stripe/webhook
# The CLI will print the webhook signing secret (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Shippo ───────────────────────────────────────────────────────────────────
# Get your API key from: https://goshippo.com/user/apikeys
# Use a TEST token during development (starts with "shippo_test_")
SHIPPO_API_KEY=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Sender / business address (printed on all outgoing labels)
SHIPPO_FROM_NAME=Aurelia Fine Jewelry
SHIPPO_FROM_STREET1=100 Fashion Ave
SHIPPO_FROM_CITY=New York
SHIPPO_FROM_STATE=NY
SHIPPO_FROM_ZIP=10018
SHIPPO_FROM_COUNTRY=US
SHIPPO_FROM_EMAIL=shipping@yourstore.com
SHIPPO_FROM_PHONE=+12125550100
